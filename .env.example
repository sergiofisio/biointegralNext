# EmailJS (formulários no navegador)
# Painel: https://dashboard.emailjs.com
# Template ID = aba Settings do template (começa com "template_")

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Formulário de contato (/contato)
NEXT_PUBLIC_EMAILJS_CONTATO_TEMPLATE_ID=
# Legado / fallback se CONTATO não estiver definido
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# Pesquisa de satisfação (/satisfacao)
NEXT_PUBLIC_EMAILJS_SATISFACTION_TEMPLATE_ID=

# Cloudflare Turnstile (anti-bot nos formulários)
# https://dash.cloudflare.com → Turnstile → Add site
# Site key (pública). Em produção: Variable NEXT_PUBLIC_TURNSTILE_SITE_KEY
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# No GitHub (environment production):
# Variables: NEXT_PUBLIC_EMAILJS_* e NEXT_PUBLIC_TURNSTILE_SITE_KEY
# Secrets: FTP_HOST, FTP_USERNAME, FTP_PASSWORD [, SFTP_KNOWN_HOSTS]
# Nunca coloque senha FTP em Variables.
# STATIC_EXPORT=true
# NEXT_PUBLIC_BUILD_ID=
