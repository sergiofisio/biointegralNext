# EmailJS (formulários no navegador)
# Painel: https://dashboard.emailjs.com
# Template ID = aba Settings do template (começa com "template_")

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Formulário de contato (/contato)
NEXT_PUBLIC_EMAILJS_CONTATO_TEMPLATE_ID=
# Legado / fallback se CONTATO não estiver definido
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# Pesquisa de satisfação (/satisfacao)
NEXT_PUBLIC_EMAILJS_SATISFACTION_TEMPLATE_ID=

# No GitHub (environment production → Variables), use os mesmos nomes NEXT_PUBLIC_*
# ou equivalentes sem prefixo (EMAILJS_SERVICE_ID, EMAILJS_PUBLIC_KEY, etc.).
# Build estático embute essas variáveis no JS — é obrigatório defini-las no CI.
# STATIC_EXPORT=true
# NEXT_PUBLIC_BUILD_ID=
