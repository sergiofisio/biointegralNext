# MailerSend (servidor — Vercel)
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=Biointegral Saúde
MAILERSEND_TO_EMAIL=contato@biointegralsaude.com.br

# Origens permitidas no CORS da API de contato (Hostinger → Vercel)
# Ex.: https://www.biointegralsaude.com.br,https://biointegralsaude.com.br
CONTACT_CORS_ORIGIN=

# URL da API de contato (build estático na Hostinger)
# Ex.: https://www.biointegralsaude.com.br/api/contact
NEXT_PUBLIC_CONTACT_API_URL=

# Build estático para Hostinger (yarn build:static)
# STATIC_EXPORT=true
