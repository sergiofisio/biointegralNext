# EmailJS (formulário de contato — client-side)
# Copie os IDs em https://dashboard.emailjs.com → Email Templates → seu template → aba Settings
# O Template ID geralmente começa com "template_" (NÃO use o ID da URL do navegador)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# EmailJS — pesquisa de satisfação (/satisfacao, página oculta)
NEXT_PUBLIC_EMAILJS_SATISFACTION_TEMPLATE_ID=

# Build estático para Hostinger (yarn build:static)
# STATIC_EXPORT=true
